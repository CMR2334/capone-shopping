{
  "bypassPermissions": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/collinrekowski/Automation/scripts/agent-session.js hook-start --platform claude"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/collinrekowski/Automation/scripts/agent-session.js hook-start --platform claude"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/collinrekowski/Automation/scripts/agent-session.js hook-pretool --platform claude"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/collinrekowski/Automation/scripts/agent-session.js hook-stop --platform claude"
          }
        ]
      }
    ]
  }
}
